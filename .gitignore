# Visual Studio Project User Options
# ----------------------------------
# This file stores user-specific options for the project.
*.suo
*.user
*.vspscc
*.vssscc

# Visual Studio Cache and Build Artifacts
# ---------------------------------------
# obj/ and bin/ directories contain compiled binaries and intermediate build files.
# These should always be ignored as they are generated from source code.
[Bb]in/
[Oo]bj/

# Visual Studio temporary files, caches, and logs
# -----------------------------------------------
# .vs/ folder: Contains solution user options, local debugger history, etc.
# These are user-specific and can be large.
.vs/
*.opensdf
*.opendb
*.VC.db # For C++ related projects, but common in VS solutions
*.VC.VC.opendb

# Package Manager (NuGet)
# -----------------------
# Packages directory might be used by older NuGet versions or specific setups.
# For newer SDK-style projects, packages are often global or in user profile.
packages/

# Project Files
# -------------
# ReSharper and similar code analysis/productivity tools' files.
# Visual Studio Code specific settings (if not shared).
*.resharper
*.resharper.user
*.resharper.[0-9]*.[0-9]*
*.idea/
.vscode/

# Local database files
# --------------------
# Common for local development databases (e.g., SQL Server LocalDB).
*.mdf
*.ldf

# Test results
# ------------
# Files generated by test runners.
TestResults/
*.trx

# Debugging files
# ---------------
# Crash dumps and other debugging artifacts.
*.aps
*.pch
*.pdb # Already covered by bin/ for generated PDBs, but good to be explicit
*.log
*.sbr
*.bsc
*.ncb
*.tlog

# User secrets (ASP.NET Core)
# ---------------------------
# If you are using ASP.NET Core user secrets, these should NOT be committed.
# The path often looks like: %APPDATA%\Microsoft\UserSecrets\your_user_secrets_guid\secrets.json
# Or for .NET 5+, if secrets.json is directly in the project folder but outside UserSecrets,
# make sure it's ignored if it contains sensitive data not meant for source control.
# usersecrets/ # Example if you store them in a local folder named usersecrets

# Published/Deployment Files
# --------------------------
# Files typically generated when publishing a project.
Publish/
*.publishproj
*.deploy

# Code generation files (e.g., T4 templates)
# ------------------------------------------
*.tt.cs # Output of T4 templates

# Miscellaneous files
# -------------------
# Thumbnail database (Windows)
Thumbs.db
# macOS specific files
.DS_Store